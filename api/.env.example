# ── DJ SaaS API Configuration ──
# Copy this to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# JWT Secrets (CHANGE THESE IN PRODUCTION — use 64+ random chars)
JWT_SECRET=CHANGE_ME_use_a_strong_random_secret
JWT_REFRESH_SECRET=CHANGE_ME_use_another_strong_random_secret

# MySQL Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=dj_saas

# LiveKit (optional — leave empty for WebRTC-only mode)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=
